# ──────────────────────────────────────────────────────────────────────
# Quorima MVP — environment configuration
# Copy to .env and fill in
# ──────────────────────────────────────────────────────────────────────

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
QUORIMA_MODEL_CFO=claude-opus-4-6
QUORIMA_MODEL_SUB=claude-haiku-4-5

# Twinfield (SOAP, session-based)
# Path A: gebruik de APARRIS user met Webservice key (geen aparte service-account
# nodig — Twinfield-pakket op KUBUSALKMAAR ondersteunt geen self-service multi-user
# beheer; aparte user-aanvraag bij Twinfield support is optioneel voor later).
TWINFIELD_ORGANISATION=KUBUSALKMAAR
TWINFIELD_USER=APARRIS
TWINFIELD_PASSWORD=
TWINFIELD_OFFICE_VASTGOED=21007
TWINFIELD_OFFICE_ICT=21005
TWINFIELD_OFFICE_HOLDING=21006

# Belangrijk: TWINFIELD_PASSWORD is de **Webservice key** (niet je gewone
# Wolters Kluwer SSO wachtwoord). Wijzig of bekijk in:
# Twinfield → Toegangsinstellingen → Gebruikers­instellingen → "Webservice key wijzigen"

# Tenant info
QUORIMA_TENANT_ID=sirrapa-group-2026
QUORIMA_REPORTING_CURRENCY=EUR

# Output channel (digest delivery)
DIGEST_OUTPUT_DIR=./output
DIGEST_RECIPIENT=armand.parris@sirrapagroup.com

# CFO agent thresholds (override defaults from KPI doc)
DSCR_RED=1.0
DSCR_YELLOW=1.25
NOI_BUDGET_EUR_MONTHLY=
WACC_RED_PCT=7
REFI_RUNWAY_RED_MONTHS=6
