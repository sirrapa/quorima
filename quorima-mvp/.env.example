# ──────────────────────────────────────────────────────────────────────
# Quorima MVP — environment configuration
# Copy to .env and fill in
# ──────────────────────────────────────────────────────────────────────

# LLM-provider voor de CFO-briefing (alleen nodig voor `npm run flash`).
# Vendor-onafhankelijk: openai/codex (default), gemini (gratis tier) of anthropic.
# Zet QUORIMA_MODEL_CFO op een model dat bij de gekozen provider hoort.
QUORIMA_LLM_PROVIDER=openai
QUORIMA_MODEL_CFO=gpt-4o-mini
OPENAI_API_KEY=
# Alleen invullen als je van provider wisselt:
# GEMINI_API_KEY=          # provider=gemini    (bv. QUORIMA_MODEL_CFO=gemini-2.5-flash)
# ANTHROPIC_API_KEY=       # provider=anthropic (bv. QUORIMA_MODEL_CFO=claude-opus-4-8)

# Twinfield (OAuth2 / OpenID Connect)
# De oude SOAP-logon (user + Webservice key) is door Twinfield uitgezet en geeft
# OAuth2AuthenticationRequired. Registreer een OAuth-app bij Twinfield voor
# client_id/secret + een redirect_uri. Daarna eenmalig: npm run twinfield:auth
# Zie connectors/twinfield_oauth2_migration.md voor de registratie-stappen.
TWINFIELD_CLIENT_ID=
TWINFIELD_CLIENT_SECRET=
TWINFIELD_REDIRECT_URI=http://localhost:8080/callback

# Office-codes per entiteit (CompanyCode in de SOAP-header)
TWINFIELD_OFFICE_VASTGOED=21007
TWINFIELD_OFFICE_ICT=21005
TWINFIELD_OFFICE_HOLDING=21006

# Optioneel: pad naar de lokale token-store (gitignored).
# Default: ./.twinfield-tokens.json
# TWINFIELD_TOKEN_STORE=./.twinfield-tokens.json

# Tenant info
QUORIMA_TENANT_ID=sirrapa-group-2026
QUORIMA_REPORTING_CURRENCY=EUR

# Output channel (digest delivery)
DIGEST_OUTPUT_DIR=./output
DIGEST_RECIPIENT=armand.parris@sirrapagroup.com

# CFO agent thresholds (override defaults from KPI doc)
DSCR_RED=1.0
DSCR_YELLOW=1.25
NOI_BUDGET_EUR_MONTHLY=
WACC_RED_PCT=7
REFI_RUNWAY_RED_MONTHS=6
